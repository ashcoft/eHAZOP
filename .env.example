# EHAZOP Platform Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=EHAZOP Platform
APP_VERSION=1.0.0
DEBUG=false

# Security - IMPORTANT: Change this in production!
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ehazop

# Redis (for rate limiting and caching)
REDIS_URL=redis://redis:6379/0

# File Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# S3/MinIO (if using S3 storage)
# S3_BUCKET=ehazop-reports
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-east-1

# LLM Provider (Gemini)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (alternative LLM)
# OPENAI_API_KEY=your-openai-api-key

# LLM Model Configuration
LLM_MODEL=gemini-2.0-flash
LLM_EMBEDDING_MODEL=text-embedding-004

# Vector Store
VECTOR_DIMENSION=768

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO